@page
@model WebProductos.Pages.Productos.EditarModel
@{
}

<header class="py-4 bg-dark text-white text-center shadow mb-4">
    <div class="container">
        <h1 class="fw-bold">
            <i class="bi bi-plus-square"></i> Editar Producto
        </h1>
        <p class="mb-0">Edita la información del producto</p>
    </div>
</header>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label">Categoría</label>
                            <select asp-for="categoriaseleccionada" class="form-select" asp-items="Model.categorias" id="categorias"onchange="fetchSubcategorias()">
                                <option value="">Seleccione una categoría</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Subcategoría</label>
                            <select asp-for="subcategoriaseleccionada" class="form-select" asp-items="Model.subcategorias" id="subcategorias">
                                <option value="">Seleccione una subcategoría</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" asp-for="producto.Nombre"></label>
                            <input class="form-control" asp-for="producto.Nombre" />
                            <span class="text-danger" asp-validation-for="producto.Nombre"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" asp-for="producto.Descripcion"></label>
                            <input class="form-control" asp-for="producto.Descripcion" />
                            <span class="text-danger" asp-validation-for="producto.Descripcion"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" asp-for="producto.Precio"></label>
                            <input class="form-control" asp-for="producto.Precio" />
                            <span class="text-danger" asp-validation-for="producto.Precio"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" asp-for="producto.Stock"></label>
                            <input class="form-control" asp-for="producto.Stock" />
                            <span class="text-danger" asp-validation-for="producto.Stock"></span>
                        </div>
                        <div class="mb-4">
                            <label class="form-label" asp-for="producto.CodigoBarras"></label>
                            <input class="form-control" asp-for="producto.CodigoBarras" />
                            <span class="text-danger" asp-validation-for="producto.CodigoBarras"></span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <a class="btn btn-outline-secondary" asp-page="./Index"> Regresar </a>
                            <button type="submit" class="btn btn-warning">Editar </button>
                        </div>
                        <input type="hidden" asp-for="producto.Id" />
                        <input type="hidden" id="subcategoriaInicial" value="@Model.subcategoriaseleccionada" />

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function fetchSubcategorias(selectedId = null) {
            const categoriaId = document.getElementById("categorias").value;
            if (!categoriaId) { return; }

            try {
                const respuesta = await fetch(`?handler=ObtenerSubcategorias&categoriaId=${categoriaId}`);
                const subcategorias = await respuesta.json();

                const subcategoriasSelect = document.getElementById("subcategorias");
                subcategoriasSelect.innerHTML = '<option value="">Seleccione una subcategoria</option>';

                subcategorias.forEach(subcategoria => {
                    const option = document.createElement("option");
                    option.value = subcategoria.id;
                    option.text = subcategoria.nombre;
                    if (selectedId && subcategoria.id.toLowerCase() === selectedId.toLowerCase()) {
                        option.selected = true;
                    }
                    subcategoriasSelect.appendChild(option);
                });

            } catch (error) {
                console.error('Error obteniendo subcategorias', error);
            }
        }

    </script>
}


}
