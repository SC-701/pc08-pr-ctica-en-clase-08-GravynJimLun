@page
@model WebProductos.Pages.Productos.IndexModel
@{
}
<header class="py-5 bg-dark text-white text-center shadow mb-4">
    <div class="container " >
        <h1 class="display-5 fw-bold">
            <i class="bi bi-box-seam"></i> Gestión de Productos
        </h1>
        <p class="lead mb-0">
            Consulta, edita y administra el inventario de productos
        </p>
    </div>
</header>

<section class="page-section bg-light">
    <div class="container">
        <div class="text-center mb-4">
            <a type="button" class="btn btn-group-lg btn-success btn-lg" asp-page="./Agregar"><i class="bi bi-plus-square"></i> Agregar</a>
        </div>
        <div class="row">
            @if (Model.productos != null)
            {
                @foreach (var producto in Model.productos)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card shadow-sm h-100 border-0">
                            <div class="card-header bg-dark text-white">
                                <h5 class="mb-0">
                                    <h5 class="mb-0">
                                        @Html.DisplayFor(modelo => producto.Nombre)
                                    </h5>
                                </h5>
                            </div>

                            <div class="card-body">
                    
                                <p class="text-muted mb-3">
                                    <p class="text-muted mb-3">
                                        @Html.DisplayFor(modelo => producto.Descripcion)
                                    </p>
                                </p>

                                <ul class="list-group list-group-flush mb-3">
                                    <li class="list-group-item">
                                        <strong>Código:</strong> @Html.DisplayFor(modelo => producto.CodigoBarras)
                                    </li>

                                    <li class="list-group-item">
                                        <strong>Precio:</strong> ₡ @Html.DisplayFor(modelo => producto.Precio)
                                    </li>

                                    <li class="list-group-item">
                                        <strong>Stock:</strong> @Html.DisplayFor(modelo => producto.Stock)
                                    </li>
                                </ul>

                            </div>

                            <div class="card-footer bg-white border-0 d-flex justify-content-between">
                                <a class="btn btn-outline-primary btn-sm"
                                       asp-page="./Detalle"
                                       asp-route-id="@producto.Id"> Detalle
                                </a>

                                <a class="btn btn-outline-warning btn-sm"
                                       asp-page="./Editar"
                                       asp-route-id="@producto.Id"> Editar
                                </a>

                                <a class="btn btn-outline-danger btn-sm"
                                       asp-page="./Eliminar"
                                       asp-route-id="@producto.Id">  Eliminar
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>